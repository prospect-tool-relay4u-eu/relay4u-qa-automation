{
  "name": "relay4u-qa-automation",
  "version": "1.0.0",
  "description": "QA automation framework for [connect.relay4u.eu](https://connect.relay4u.eu) — a LinkedIn contact management tool.",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:no-quota": "playwright test --grep-invert @email-quota",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prospect-tool-relay4u-eu/relay4u-qa-automation.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/prospect-tool-relay4u-eu/relay4u-qa-automation/issues"
  },
  "homepage": "https://github.com/prospect-tool-relay4u-eu/relay4u-qa-automation#readme",
  "lint-staged": {
    "*.js": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.5.0",
    "@playwright/test": "^1.61.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^2.10.5",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "prettier": "^3.9.5"
  }
}
